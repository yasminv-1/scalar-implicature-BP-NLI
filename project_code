print("=" * 60)

RUBRIC_QUESTIONS = [
    "Q1_scalar_identified",
    "Q2_pragmatic_reasoning",
    "Q3_label_consistent",
]

def merge_task2_annotations(model_name, annotators, questions):
    dfs = []
    for ann in annotators:
        fname = f"cot_task2_{model_name}_{ann}.csv"
        try:
            df = pd.read_csv(fname)
            df = df[["premise"] + questions].rename(
                columns={q: f"{q}_{ann}" for q in questions}
            )
            dfs.append(df)
            print(f"  Loaded: {fname}")
        except FileNotFoundError:
            print(f"  WARNING: {fname} not found — skipping.")

    if not dfs:
        print(f"  No Task 2 files found for {model_name}.")
        return

    merged = dfs[0]
    for df in dfs[1:]:
        merged = merged.merge(df, on="premise", how="inner")

    present_anns = [a for a in annotators
                    if f"{questions[0]}_{a}" in merged.columns]

    print(f"\n  IAA Results — {model_name} CoT traces:")
    print(f"  {'Question':<38} {'Avg κ':>8}")
    print(f"  {'-'*48}")

    for q in questions:
        q_cols = [f"{q}_{ann}" for ann in present_anns]
        sub    = merged[["premise"] + q_cols].dropna()
        for col in q_cols:
            sub[col] = sub[col].astype(int)
        pairs  = [(present_anns[i], present_anns[j])
                   for i in range(len(present_anns))
                   for j in range(i+1, len(present_anns))]
        kappas = [
            cohen_kappa_score(sub[f"{q}_{a1}"], sub[f"{q}_{a2}"])
            for a1, a2 in pairs
        ]
        print(f"  {q:<38} {np.mean(kappas):>8.3f}")
        merged[f"{q}_final"] = (
            merged[q_cols].sum(axis=1) >= 3
        ).astype(int)

    q_final_cols = [f"{q}_final" for q in questions]
    summary      = merged[q_final_cols].mean()

    label_map = {
        "Q1_scalar_identified_final":
            "Q1: Scalar term identified?",
        "Q2_pragmatic_reasoning_final":
            "Q2: Pragmatic reasoning present?",
        "Q3_label_consistent_final":
            "Q3: Label consistent with reasoning?",
    }
    print(f"\n  Final rubric scores (majority vote, proportion):")
    for col, label in label_map.items():
        if col in summary:
            print(f"    {label:<42} {summary[col]:.2f}")

    merged.to_csv(f"cot_merged_{model_name}.csv", index=False)
    print(f"\n  Saved cot_merged_{model_name}.csv")


merge_task2_annotations("sabia",   ANNOTATORS, RUBRIC_QUESTIONS)
