def load_manual_extractions(filepaths):
    """
    Load one or more manually filled extraction sheets.

    Usage (single):
        raw_df = load_manual_extractions(
            ["manual_extraction_sheet.csv"])
    Usage (multiple extractors):
        raw_df = load_manual_extractions([
            "extraction_person1.csv",
            "extraction_person2.csv",
        ])
    """
    dfs = []
    for fp in filepaths:
        try:
            df = pd.read_csv(fp, encoding="utf-8")
            print(f"  Loaded {fp}: {len(df)} rows")
            dfs.append(df)
        except FileNotFoundError:
            print(f"  WARNING: {fp} not found — skipping.")

    if not dfs:
        print("  ERROR: No extraction files found.")
        return pd.DataFrame()

    combined = pd.concat(dfs, ignore_index=True)

    required = ["premise", "scalar_term", "corpus", "style"]
    missing  = [c for c in required if c not in combined.columns]
    if missing:
        print(f"  ERROR: Missing columns: {missing}")
        return pd.DataFrame()

    combined = combined.dropna(subset=["premise"])
    combined["premise"]     = combined["premise"].str.strip()
    combined["scalar_term"] = (combined["scalar_term"]
                                .str.strip().str.lower())
    combined = combined.drop_duplicates(subset=["premise"])

    print(f"\n  Total after deduplication: {len(combined)}")
    print(f"\n  By corpus:")
    print(combined["corpus"].value_counts().to_string())
    print(f"\n  By style:")
    print(combined["style"].value_counts().to_string())
    print(f"\n  By scalar term:")
    print(combined["scalar_term"].value_counts().to_string())

    unknown = (set(combined["scalar_term"])
               - set(scalar_map.keys())
               - {"todos", "todas", "nenhum", "nenhuma",
                  "ninguém", "todo mundo"})
    if unknown:
        print(f"\n  WARNING: These scalar terms have no auto-mapping "
              f"and will need manually written hypotheses: {unknown}")

    combined.to_csv("raw_extractions.csv", index=False,
                    encoding="utf-8")
    print(f"\n  Saved raw_extractions.csv")
    return combined


