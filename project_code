def merge_task1_annotations(annotators):
    dfs = []
    for ann in annotators:
        fname = f"annotation_task1_{ann}.csv"
        try:
            df = pd.read_csv(fname)
            df = df[["premise", "keep"]].rename(
                columns={"keep": f"keep_{ann}"}
            )
            dfs.append(df)
            print(f"  Loaded: {fname}")
        except FileNotFoundError:
            print(f"  WARNING: {fname} not found — skipping.")

    if not dfs:
        print("  No annotation files found. Run Stage 3 first.")
        return pd.DataFrame()

    merged = dfs[0]
    for df in dfs[1:]:
        merged = merged.merge(df, on="premise", how="inner")

    keep_cols    = [f"keep_{ann}" for ann in annotators
                    if f"keep_{ann}" in merged.columns]
    merged       = merged.dropna(subset=keep_cols)
    for col in keep_cols:
        merged[col] = merged[col].astype(int)

    # Pairwise Cohen's Kappa
    print("\n  Pairwise Cohen's Kappa (Task 1 — keep/discard):")
    print("  " + "-" * 45)
    present_anns = [a for a in annotators
                    if f"keep_{a}" in merged.columns]
    pairs  = [(present_anns[i], present_anns[j])
               for i in range(len(present_anns))
               for j in range(i + 1, len(present_anns))]
    kappas = []
    for a1, a2 in pairs:
        k = cohen_kappa_score(merged[f"keep_{a1}"],
                              merged[f"keep_{a2}"])
        kappas.append(k)
        print(f"  {a1} vs {a2}: κ = {k:.3f}")

    avg_k = np.mean(kappas)
    print(f"\n  Average κ: {avg_k:.3f}")

    if   avg_k >= 0.80: interp = "Almost perfect agreement"
    elif avg_k >= 0.60: interp = "Substantial agreement"
    elif avg_k >= 0.40: interp = "Moderate agreement — acceptable"
    else:               interp = "Poor — revise annotation guidelines"
    print(f"  Interpretation: {interp}")

    # Majority vote (3 or more → keep)
    merged["keep_votes"] = merged[keep_cols].sum(axis=1)
    merged["final_keep"] = (merged["keep_votes"] >= 2).astype(int)

    total             = len(merged)
    kept              = int(merged["final_keep"].sum())
    unanimous_keep    = int((merged["keep_votes"] ==
                              len(keep_cols)).sum())
    unanimous_discard = int((merged["keep_votes"] == 0).sum())

    print(f"\n  Agreement Summary:")
    print(f"    Total reviewed:          {total}")
    print(f"    Unanimous keep:          {unanimous_keep}")
    for v in range(len(keep_cols) - 1, 0, -1):
        cnt = int((merged["keep_votes"] == v).sum())
        print(f"    {v}/{len(keep_cols)} keep:                  {cnt}")
    print(f"    Unanimous discard:       {unanimous_discard}")
    print(f"    ─────────────────────────")
    print(f"    Final kept:              {kept}")
    print(f"    Final discarded:         {total - kept}")

    merged.to_csv("merged_annotations_task1.csv", index=False)
    print(f"\n  Saved merged_annotations_task1.csv")
    return merged

