def cetenfolha_to_csv(filepath="CETENFolha-1.0.gz",
                      output_csv="cetenfolha_sentences.csv",
                      max_sentences=50000):
    """
    Convert CETENFolha .gz file into a searchable CSV.
    Run this ONCE before browsing. Then open the output
    CSV in Google Sheets to browse sentences.

    Usage:
        cetenfolha_to_csv("CETENFolha-1.0.gz")
    """
    if not os.path.exists(filepath):
        print(f"  ERROR: {filepath} not found.")
        print(f"  Upload CETENFolha-1.0.gz to Colab first.")
        return pd.DataFrame()

    print(f"Converting {filepath} → {output_csv}...")
    f_opener = gzip.open if filepath.endswith(".gz") else open
    results  = []

    with f_opener(filepath, "rt", encoding="latin-1") as f:
        text = f.read()

    text      = re.sub(r"<[^>]+>", " ", text)
    text      = re.sub(r"\s+", " ", text)
    sentences = re.split(r"(?<=[.!?])\s+", text)

    for i, sent in enumerate(sentences):
        sent = sent.strip()
        if len(sent.split()) < 6 or len(sent.split()) > 60:
            continue
        if re.search(r"[<>{}\\|]", sent):
            continue
        words       = sent.split()
        alpha_ratio = sum(1 for w in words if w.isalpha()) / len(words)
        if alpha_ratio < 0.5:
            continue
        results.append({
            "line_number": i,
            "text":        sent,
            "corpus":      "CETENFolha",
            "style":       "formal_written",
        })
        if len(results) >= max_sentences:
            break

    df = pd.DataFrame(results)
    df.to_csv(output_csv, index=False, encoding="utf-8")
    print(f"  Done. Saved {len(df)} sentences → {output_csv}")
    print(f"  Download and open in Google Sheets to browse.")
    return df


def merge_csvs(filepaths, output_filename, text_column="text"):
    """
    Merge multiple CSV files into one and save.
    Use this to combine the 3-part CORAA and NURC-SP files.

    Usage:
        merge_csvs(
            ["coraa_part1.csv", "coraa_part2.csv", "coraa_part3.csv"],
            "coraa_merged.csv"
        )
        merge_csvs(
            ["nurc_part1.csv", "nurc_part2.csv", "nurc_part3.csv"],
            "nurc_merged.csv"
        )
    """
    dfs = []
    for f in filepaths:
        try:
            df = pd.read_csv(f, low_memory=False)
            print(f"  {f}: {len(df)} rows")
            dfs.append(df)
        except FileNotFoundError:
            print(f"  WARNING: {f} not found — skipping.")

    if not dfs:
        print("  No files loaded.")
        return pd.DataFrame()

    merged = pd.concat(dfs, ignore_index=True).drop_duplicates()

    if text_column in merged.columns:
        merged = merged.dropna(subset=[text_column])

    merged.to_csv(output_filename, index=False, encoding="utf-8")
    print(f"\n  Total rows: {len(merged)}")
    print(f"  Saved: {output_filename}")
    return merged


def create_extraction_sheet():
    """
    Create a blank extraction sheet for manual filling.

    Columns:
      premise     — sentence you selected from the corpus
      scalar_term — the weak scalar word in the sentence
      hypothesis  — leave blank for corpus sentences (auto-generated)
                    REQUIRED for filler rows
      label       — leave blank for corpus sentences (auto = neutral)
                    REQUIRED for filler rows: entailment or contradiction
      corpus      — CETENFolha / CORAA / NURC-SP / filler
      style       — formal_written / formal_spoken / informal_spoken
      source_line — optional: row number in source file
      extractor   — your name
      notes       — anything worth flagging

    FILLER ROWS (corpus = filler):
      Entailment:
        premise    : Todos os alunos passaram no exame.
        hypothesis : Alguns alunos passaram no exame.
        label      : entailment
        scalar_term: todos
        corpus     : filler
      Contradiction:
        premise    : Nenhum aluno passou no exame.
        hypothesis : Alguns alunos passaram no exame.
        label      : contradiction
        scalar_term: nenhum
        corpus     : filler

    Target: 50 entailment + 50 contradiction fillers
            distributed across all three styles.
    """
    sheet = pd.DataFrame(columns=[
        "premise", "scalar_term", "hypothesis", "label",
        "corpus", "style", "source_line", "extractor", "notes",
    ])
    sheet.to_csv("manual_extraction_sheet.csv", index=False,
                 encoding="utf-8")
    print("Created: manual_extraction_sheet.csv")
    print("Fill this in before running Stage 2.")
    print("Remember: fill hypothesis + label for ALL filler rows.")


def browse_all(corpora=CORPORA, scalar_terms=SCALAR_TERMS,
               n_per_term=20, informal_threshold=200):
    """
    Browse all scalar terms across all corpora and print results.
    Copy sentences you want into manual_extraction_sheet.csv.

   
    Usage:
        browse_all(n_per_term=20)
        browse_all(corpora=[CORPORA[0]], n_per_term=30)
        browse_all(scalar_terms=["alguns", "muitos"], n_per_term=30)
    """
    nurc_count = 0

    for corpus in corpora:
        filepath       = corpus["filepath"]
        corpus_name    = corpus["corpus_name"]
        style          = corpus["style"]
        text_col       = corpus["text_column"]
        filter_column  = corpus.get("filter_column")
        filter_value   = corpus.get("filter_value")
        is_backup      = "backup_for" in corpus

        # Load corpus
        try:
            df = pd.read_csv(filepath, low_memory=False)
        except FileNotFoundError:
            print(f"  FILE NOT FOUND: {filepath}")
            print(f"  Make sure this file is uploaded to Colab.")
            continue

        if text_col not in df.columns:
            print(f"  ERROR: column '{text_col}' not found.")
            print(f"  Available columns: {df.columns.tolist()}")
            continue

        # Apply filter
        if filter_column and filter_value:
            if filter_column not in df.columns:
                print(f"  ERROR: filter column '{filter_column}' "
                      f"not found.")
                continue
            df = df[df[filter_column] == filter_value].copy()
            print(f"  Rows after filter: {len(df)}")

        # Browse each scalar term
        corpus_sentence_count = 0

        for term in scalar_terms:
            mask    = df[text_col].str.contains(
                r"\b" + re.escape(term) + r"\b",
                case=False, na=False, regex=True
            )
            matches = df[mask].head(n_per_term)
            total   = mask.sum()

            if total == 0:
                continue

            shown = 0
            print(f"\n  ── Scalar term: '{term}' "
                  f"({total} total matches, "
                  f"showing up to {n_per_term}) ──\n")

            for i, row in matches.iterrows():
                sentence = str(row[text_col]).strip()
                words    = sentence.split()
                if len(words) < 6 or len(words) > 50:
                    continue
                print(f"  [row {i} | {corpus_name} | "
                      f"{style} | {term}]")
                print(f"  {sentence}")
                print()
                shown += 1

            corpus_sentence_count += shown

      

def browse_all_to_file(output_file="browse_results.txt",
                       corpora=CORPORA,
                       scalar_terms=SCALAR_TERMS,
                       n_per_term=20,
                       informal_threshold=200):
    """
    Same as browse_all but saves to a text file instead of
    printing.
    Download browse_results.txt from the file panel and open
    in any text editor or Google Docs.

    Usage:
        browse_all_to_file(n_per_term=20)
    """
    lines      = []
    nurc_count = 0

    for corpus in corpora:
        filepath       = corpus["filepath"]
        corpus_name    = corpus["corpus_name"]
        style          = corpus["style"]
        text_col       = corpus["text_column"]
        filter_column  = corpus.get("filter_column")
        filter_value   = corpus.get("filter_value")
        is_backup      = "backup_for" in corpus

        if is_backup:
            if nurc_count >= informal_threshold:
                lines.append(f"\nBACKUP SKIPPED — NURC-SP had "
                             f"{nurc_count} sentences "
                             f"(threshold: {informal_threshold})")
                continue
            else:
                lines.append("\n" + "=" * 70)
                lines.append(f"BACKUP ACTIVATED: CORAA Spontaneous Speech")
                lines.append(f"NURC-SP only had {nurc_count} sentences")
                lines.append("=" * 70)
        else:
            lines.append("\n" + "=" * 70)
            lines.append(f"CORPUS: {corpus_name}  |  Style: {style}")
            if filter_column:
                lines.append(f"Filter: {filter_column} = "
                             f"'{filter_value}'")
            lines.append("=" * 70)

        try:
            df = pd.read_csv(filepath, low_memory=False)
        except FileNotFoundError:
            lines.append(f"FILE NOT FOUND: {filepath}")
            continue

        if text_col not in df.columns:
            lines.append(f"ERROR: column '{text_col}' not found.")
            lines.append(f"Columns: {df.columns.tolist()}")
            continue

        if filter_column and filter_value:
            df = df[df[filter_column] == filter_value].copy()

        corpus_sentence_count = 0

        for term in scalar_terms:
            mask    = df[text_col].str.contains(
                r"\b" + re.escape(term) + r"\b",
                case=False, na=False, regex=True
            )
            matches = df[mask].head(n_per_term)
            total   = mask.sum()

            if total == 0:
                continue

            lines.append(f"\n── Scalar term: '{term}' "
                        f"({total} total, "
                        f"showing up to {n_per_term}) ──\n")

            for i, row in matches.iterrows():
                sentence = str(row[text_col]).strip()
                words    = sentence.split()
                if len(words) < 6 or len(words) > 50:
                    continue
                lines.append(f"[row {i} | {corpus_name} | "
                             f"{style} | {term}]")
                lines.append(sentence)
                lines.append("")
                corpus_sentence_count += 1

        if corpus_name == "NURC-SP":
            nurc_count = corpus_sentence_count
            lines.append(f"\nNURC-SP total: {nurc_count} sentences")

    with open(output_file, "w", encoding="utf-8") as f:
        f.write("\n".join(lines))

    print(f"Saved {len(lines)} lines → {output_file}")
    print("Download from the Colab file panel.")


