# STAGE 6: BUILD HYPOTHESIS PAIRS
# Fillers come from your extraction sheet (corpus = filler).
# Corpus sentences get neutral label + the auto-generated hypothesis.
# Filler sentences keep their manually written label + hypothesis.
#
# FILLER TARGET: 50 entailment + 50 contradiction = 100 total

print("\n" + "=" * 60)
print("STAGE 6: BUILDING HYPOTHESIS PAIRS")
print("=" * 60)

def make_hypothesis(premise, scalar_term):
    if not isinstance(scalar_term, str) or not scalar_term.strip():
        return None
    strong = scalar_map.get(scalar_term.strip().lower())
    if strong is None:
        return None
    return re.sub(
        r"\b" + re.escape(scalar_term.strip()) + r"\b",
        strong, premise, flags=re.IGNORECASE
    )
try:
    kept_df = pd.read_csv("kept_sentences.csv")

    is_filler  = kept_df["corpus"] == "filler"
    filler_df  = kept_df[is_filler].copy()
    corpus_df  = kept_df[~is_filler].copy()

    print(f"  Corpus sentences: {len(corpus_df)}")
    print(f"  Filler sentences: {len(filler_df)}")

    # Corpus sentences — neutral label, auto hypothesis
    def resolve_hypothesis(row):
        if ("hypothesis" in row
                and pd.notna(row["hypothesis"])
                and str(row["hypothesis"]).strip() != ""):
            return str(row["hypothesis"]).strip()
        return make_hypothesis(row["premise"], row["scalar_term"])

    corpus_df["hypothesis"] = corpus_df.apply(
        resolve_hypothesis, axis=1)
    corpus_df["label"] = "neutral"
    corpus_df = corpus_df.dropna(subset=["hypothesis"])
    print(f"  Corpus pairs after hypothesis generation: "
          f"{len(corpus_df)}")

    # Filler sentences — use manually written hypothesis + label
    if len(filler_df) > 0:
        filler_df = filler_df.dropna(subset=["hypothesis", "label"])
        ent  = (filler_df["label"] == "entailment").sum()
        cont = (filler_df["label"] == "contradiction").sum()
        print(f"  Fillers — entailment: {ent}, "
              f"contradiction: {cont}")
        if abs(ent - cont) > 10:
            print(f"  WARNING: Filler classes are unbalanced. "
                  f"Consider adding more to the smaller class.")

    # Combine
    full_df = pd.concat([corpus_df, filler_df], ignore_index=True)
    full_df = full_df.drop_duplicates(subset=["premise"])
    full_df.to_csv("annotated_dataset.csv", index=False)

    print(f"\n  Total dataset: {len(full_df)}")
    print(f"\n  Label distribution:")
    print(full_df["label"].value_counts().to_string())
    print(f"\n  Style × Label:")
    print(full_df.groupby(["style", "label"])
                 .size().unstack(fill_value=0).to_string())
    print(f"\n  Corpus × Label:")
    print(full_df.groupby(["corpus", "label"])
                 .size().unstack(fill_value=0).to_string())

    if len(full_df) < 600:
        print(f"\n  NOTE: Dataset below 700 target. Consider "
              f"extracting more sentences.")

except FileNotFoundError:
